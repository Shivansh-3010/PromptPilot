# ==========================================
# PromptPilot: Zero-Cost Environment Config
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=development
API_BASE_URL=https://promptpilot-backend.onrender.com

# 1. Supabase Postgres Database (Free Tier with pgvector)
# Get from Supabase Project Settings -> Database -> Connection string -> URI
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# 2. Meta WhatsApp Cloud API Direct (Free 1,000 conversations/month)
# Get from Meta for Developers -> App Dashboard -> WhatsApp -> API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAG..._your_meta_system_user_or_temporary_token
WHATSAPP_VERIFY_TOKEN=promptpilot_secret_verify_token_2026
WHATSAPP_APP_SECRET=your_meta_app_secret_for_hmac_signature_verification

# 3. AI Inference Providers (Free Tiers)
# Google AI Studio API Key (Free tier: 15 RPM / 1M TPM for Gemini 1.5 Flash, 2 RPM for 1.5 Pro)
GEMINI_API_KEY=AIzaSy...your_free_google_ai_studio_api_key

# Groq Cloud API Key (Free tier: Llama 3 8B / 70B ultra-fast fallback & translation)
GROQ_API_KEY=gsk_...your_free_groq_api_key

# Security & Rate Limiting
JWT_SECRET=super_secret_jwt_key_for_dashboard_authentication
RATE_LIMIT_MAX_REQUESTS=15
